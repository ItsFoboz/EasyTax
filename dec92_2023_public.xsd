<?xml version="1.0" encoding="WINDOWS-1251"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:element name="dec92">
		<xs:annotation>
			<xs:documentation> чл. 92 от ЗКПО за данъчния финансов резултат и дължимия годишен корпоративен данък</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:all minOccurs="0">
				<xs:element name="part13">
					<xs:annotation>
						<xs:documentation>Данни за задълженото лице (ЧастI, ЧастII,ЧастIII )</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:all>
							<xs:element name="part1">
								<xs:annotation>
									<xs:documentation>Част І – Данни за декларацията</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:all>
										<xs:element name="decyear">
											<xs:annotation>
												<xs:documentation>Данъчна година </xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:maxLength value="4"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="iscalyear" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>За календарната година - на основание чл.92, ал.1 от ЗКПО</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="istax" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>За данъка върху разходите – на основание чл.217 от ЗКПО</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isterminate75" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>На основание чл. 75, ал. 3 от ЗКПО (еднократно след срока за подаване)</xs:documentation>
											</xs:annotation>
										</xs:element>
									</xs:all>
								</xs:complexType>
							</xs:element>
							<xs:element name="part2">
								<xs:annotation>
									<xs:documentation>Част ІI - Идентификационни данни за данъчно задълженото лице</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:all>
										<xs:element name="bulstat" type="bulstat">
											<xs:annotation>
												<xs:documentation>ЕИК по ЗТРРЮЛНЦ/ЕИК по БУЛСТАТ</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="regfullname">
											<xs:annotation>
												<xs:documentation>Наименование  </xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:maxLength value="200"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="isforeign" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Чуждестранно лице</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="foreignname" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Наименование на чуждестранното лице</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:maxLength value="200"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="isnofin" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Нефинансово предприятие</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isfin" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Финансова институция</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isinsurer" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Застраховател</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isassoc" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Неперсонифицирано дружество или осигурителна каса</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isjuridical" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Юридическо лице с нестопанска цел </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="ishybrid" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Хибридно образувание по чл. 2, ал. 4 от ЗКПО</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="officeaddress" type="address" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Адрес за кореспонденция</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="pjurpersons" id="P2D1">
											<xs:annotation>
												<xs:documentation>Данни за представляващия</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="rowenum" maxOccurs="unbounded">
														<xs:complexType>
															<xs:all>
																<xs:element name="name">
																	<xs:simpleType>
																		<xs:restriction base="xs:string">
																			<xs:maxLength value="200"/>
																		</xs:restriction>
																	</xs:simpleType>
																</xs:element>
																<xs:element name="egn" type="egn"/>
															</xs:all>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="acountantperson" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Данни за съставителя на
годишния финансов отчет: Физическо лице</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:all>
													<xs:element name="isperson" type="xs:boolean">
														<xs:annotation>
															<xs:documentation>Физическо лице</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="name">
														<xs:annotation>
															<xs:documentation>Име, презиме, фамилия</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
															<xs:restriction base="xs:string">
																<xs:maxLength value="200"/>
															</xs:restriction>
														</xs:simpleType>
													</xs:element>
													<xs:element name="egn" type="egn">
														<xs:annotation>
															<xs:documentation>ЕГН/ЛН/ЛНЧ/Служебен № от регистъра на НАП</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="isworking" type="xs:boolean" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Вид на правоотношението със съставителя: трудово</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="isobligational" type="xs:boolean" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Вид на правоотношението със съставителя: облигационно, в т.ч. със съдружник, упражняващ личен труд</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:all>
											</xs:complexType>
										</xs:element>
										<xs:element name="acountantfirm" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Данни за съставителя на
годишния финансов отчет: Счетоводно предприятие</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:all>
													<xs:element name="isfirm" type="xs:boolean">
														<xs:annotation>
															<xs:documentation>Счетоводно предприятие</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="name">
														<xs:annotation>
															<xs:documentation>Наименование</xs:documentation>
														</xs:annotation>
														<xs:simpleType>
															<xs:restriction base="xs:string">
																<xs:maxLength value="200"/>
															</xs:restriction>
														</xs:simpleType>
													</xs:element>
													<xs:element name="bulstat" type="bulstat">
														<xs:annotation>
															<xs:documentation>ЕИК по ЗТРРЮЛНЦ/ЕИК по БУЛСТАТ</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:all>
											</xs:complexType>
										</xs:element>
									</xs:all>
								</xs:complexType>
							</xs:element>
							<xs:element name="part3">
								<xs:annotation>
									<xs:documentation>Част ІІІ – Данни за дейността на данъчно задълженото лице </xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:all>
										<xs:element name="baseactcode">
											<xs:annotation>
												<xs:documentation>Код на основната дейност</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:int">
													<xs:minInclusive value="0"/>
													<xs:maxInclusive value="99999"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="baseactname" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Основна дейност - наименование</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:maxLength value="200"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="isforeignplace" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Място на стопанска дейност в чужбина</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isforeignincome" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Получени доходи от източници в чужбина </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isremise1" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Преотстъпване на корпоративен данък и/или намаление на счетоводния финансов резултат по реда на глава двадесет и втора от ЗКПО</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isremise2" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Изпълнение на изискването по чл.167, ал.1 от ЗКПО</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isedict189" type="xs:boolean" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Прилагане на чл. 189 от ЗКПО - държавна помощ за регионално развитие</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="isedict1891" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Дейността, свързана с първоначалната инвестиция, се осъществява в съответната община за период от поне 5 години след годината на завършване на първоначалната инвестиция, свързана с преотстъпен корпоративен данък до 2021 г. включително, съгласно чл. 189, т. 3, б. „в“ от ЗКПО. </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="edict1891" id="P2D3" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Години на завършване на първоначалната инвестиция</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence minOccurs="0">
													<xs:element name="rowenum" maxOccurs="unbounded">
														<xs:complexType>
															<xs:all>
																<xs:element name="edict1891year">
																	<xs:annotation>
																		<xs:documentation>Година на завършване на първоначалната инвестиция, по отношение на която е налице задължение за продължаване на дейността за период поне 5 години след годината на завършване на първоначалната инвестиция</xs:documentation>
																	</xs:annotation>
																	<xs:simpleType>
																		<xs:restriction base="xs:string">
																			<xs:maxLength value="4"/>
																		</xs:restriction>
																	</xs:simpleType>
																</xs:element>
															</xs:all>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="isedict189b" type="xs:boolean">
											<xs:annotation>
												<xs:documentation>Дейността по чл. 189б, ал. 1 (производство на непреработена растителна и животинска продукция) продължава да се осъществява за период от поне три години след годината на преотстъпване</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="edict189b" id="P2D4" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Години на преотстъпване на корпоративен данък</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence minOccurs="0">
													<xs:element name="rowenum" maxOccurs="unbounded">
														<xs:complexType>
															<xs:all>
																<xs:element name="edict189byear">
																	<xs:annotation>
																		<xs:documentation>Година на преотстъпване на корпоративен данък, по отношение на която е налице задължение за продължаване на дейността за период поне 3 години след годината на преотстъпване </xs:documentation>
																	</xs:annotation>
																	<xs:simpleType>
																		<xs:restriction base="xs:string">
																			<xs:maxLength value="4"/>
																		</xs:restriction>
																	</xs:simpleType>
																</xs:element>
															</xs:all>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:all>
								</xs:complexType>
							</xs:element>
						</xs:all>
					</xs:complexType>
				</xs:element>
				<xs:element name="part4">
					<xs:annotation>
						<xs:documentation>Част ІV – Образци и документи, които се подават заедно с декларацията</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:all>
							<xs:element name="issetapp1" type="xs:boolean">
								<xs:annotation>
									<xs:documentation>Приложение № 1 за ползване на данъчни облекчения под формата на преотстъпване на корпоративен данък или чрез признаване за данъчни цели на счетоводни разходи за дарения или стипендии</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="issetapp2" type="xs:boolean">
								<xs:annotation>
									<xs:documentation>Приложение № 2 за печалби (доходи), обложени в чужбина, за които се прилага метод за избягване на двойното данъчно облагане</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="issetapp3" type="xs:boolean">
								<xs:annotation>
									<xs:documentation>Приложение № 3 за регулиране на разходите по заеми по реда на чл. 43а от ЗКПО</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="issetapp4" type="xs:boolean">
								<xs:annotation>
									<xs:documentation>Приложение № 4 за определяне на временна солидарна вноска за генерираните свръхпечалби</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="issetfinacount" type="xs:boolean">
								<xs:annotation>
									<xs:documentation>Годишен отчет за дейността</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="finnum" type="xs:string" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Вх. № и дата на годишния отчет за дейността </xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="isnoobligation" type="xs:boolean" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Не е налице задължение за подаване на годишен отчет за дейността </xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="isdocuments" type="xs:boolean" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Други документи</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="documents" type="xs:int" minOccurs="0">
								<xs:annotation>
									<xs:documentation>броя на документите</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:all>
					</xs:complexType>
				</xs:element>
				<xs:element name="part5">
					<xs:annotation>
						<xs:documentation>Част V – Определяне на данъчния финансов резултат и дължимия корпоративен данък </xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:all minOccurs="0">
							<xs:element name="result" minOccurs="0">
								<xs:annotation>
									<xs:documentation>СЧЕТОВОДЕН ФИНАНСОВ РЕЗУЛТАТ </xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:all minOccurs="0">
										<xs:element name="index0100" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>ОБЩО ПРИХОДИ </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0110" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>в т.ч. нетни приходи от продажби </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0111" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>в т.ч. нетни приходи от продажби от дейността, подлежаща на облагане с корпоративен данък </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0200" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>ОБЩО РАЗХОДИ </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0310" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>СЧЕТОВОДЕН ФИНАНСОВ РЕЗУЛТАТ: Счетоводна печалба </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0320" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>СЧЕТОВОДЕН ФИНАНСОВ РЕЗУЛТАТ: Счетоводна загуба</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0400" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Общо приходи, които се изключват при определяне на счетоводния финансов резултат за данъчно преобразуване  </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0500" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Общо разходи, които се изключват при определяне на счетоводния финансов резултат за данъчно преобразуване  </xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0610" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>СЧЕТОВОДЕН ФИНАНСОВ РЕЗУЛТАТ ЗА ДАНЪЧНО ПРЕОБРАЗУВАНЕ: ПОЛОЖИТЕЛЕН</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="index0620" type="xs:float" minOccurs="0">
											<xs:annotation>
												<xs:documentation>СЧЕТОВОДЕН ФИНАНСОВ РЕЗУЛТАТ ЗА ДАНЪЧНО ПРЕОБРАЗУВАНЕ: ОТРИЦАТЕЛЕН</xs:documentation>
											</xs:annotation>
										</xs:element>
									</xs:all>
								</xs:complexType>
							</xs:element>
							<xs:element name="reform" minOccurs="0">
								<xs:annotation>
									<xs:documentation>ПРЕОБРАЗУВАНЕ НА СЧЕТОВОДНИЯ ФИНАНСОВ РЕЗУЛТАТ </xs:documentation>
								</xs:annotation>
