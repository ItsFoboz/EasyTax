# ─── Supabase ─────────────────────────────────────────────────────────────────
# Public — bundled into the browser. Used by @supabase/ssr.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Server-only — never exposed to the browser. Used for admin tasks
# (bypassing RLS for trusted operations like the GDPR delete endpoint).
SUPABASE_SERVICE_ROLE_KEY=ey...

# ─── Anthropic (Phase 3 — invoice OCR) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Resend (Phase 4 — email delivery) ────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@yourdomain.bg

# ─── EGN encryption ───────────────────────────────────────────────────────────
# 32 bytes, base64-encoded. Used for AES-256-GCM application-level encryption
# of the egn column before write. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EGN_ENCRYPTION_KEY=

# ─── BNB (Bulgarian National Bank) exchange rate feed ─────────────────────────
# No key required — public XML feed. URL kept here so it can be swapped in tests.
BNB_RATE_FEED_URL=https://www.bnb.bg/Statistics/StExternalSector/StExchangeRates/StERForeignCurrencies/index.htm
